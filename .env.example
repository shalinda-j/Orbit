# Multi-Agent 360 CLI configuration

# ── Token controls (optional) ──
# ORBIT_MAX_TOKENS=4096   # cap output tokens per model call (lower = cheaper)
# ORBIT_LAZY=1            # ponytail mode: fewest agents, terse output, hard ≤1024-token cap

# NVIDIA Build API (https://build.nvidia.com - Free Endpoint available)
# Supports: nemotron-3-ultra, kimi-k2.6, deepseek-v4-pro, glm-5.1
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Google Gemini API Key (Get one from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# OpenAI API Key (Get one from OpenAI Platform)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Anthropic API Key (Get one from Anthropic Console)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_DEFAULT_MODEL=claude-3-5-haiku-20241022

# Ollama local configuration (optional local LLMs)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# Custom — ANY OpenAI-compatible provider with a base URL you specify (vLLM, LM Studio, self-hosted, ...)
# Only CUSTOM_BASE_URL is required; the key is optional for local endpoints.
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_DEFAULT_MODEL=

# Preset OpenAI-compatible providers — base URL is baked in, just add the key.
# Override the model with <NAME>_MODEL, or the endpoint with <NAME>_BASE_URL.
OPENROUTER_API_KEY=      # https://openrouter.ai
ZAI_API_KEY=             # z.ai / Zhipu GLM
KIMI_API_KEY=            # Moonshot Kimi
GROQ_API_KEY=            # Groq
DEEPSEEK_API_KEY=        # DeepSeek
TOGETHER_API_KEY=        # Together AI
MISTRAL_API_KEY=         # Mistral
XAI_API_KEY=             # xAI (Grok)
FIREWORKS_API_KEY=       # Fireworks

# Claude Code subscription — NO API key. Install Claude Code and log in (run `claude`
# once, or `claude setup-token`); orbit auto-detects the `claude` CLI and prefers it.
# Optional overrides:
# CLAUDE_CODE_BIN=claude
# CLAUDE_CODE_MODEL=sonnet
