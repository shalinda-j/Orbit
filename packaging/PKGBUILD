# Maintainer: Shalinda J
# AUR package for orbit — after publishing: paru -S orbit-cli   (or yay -S orbit-cli)
# Update pkgver + the source tarball's sha256 (or keep SKIP for git snapshots) before submitting.
pkgname=orbit-cli
pkgver=1.0.1
pkgrel=1
pkgdesc="Multi-agent, multi-provider AI team CLI"
arch=('any')
url="https://github.com/shalinda-j/Orbit"
license=('ISC')
depends=('nodejs>=18')
makedepends=('npm')
source=("$pkgname-$pkgver.tar.gz::https://github.com/shalinda-j/Orbit/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
  cd "$srcdir/orbit-$pkgver"
  npm install --omit=dev

  install -d "$pkgdir/usr/lib/$pkgname"
  cp -r bin src plugins examples package.json node_modules "$pkgdir/usr/lib/$pkgname/"

  install -d "$pkgdir/usr/bin"
  cat > "$pkgdir/usr/bin/orbit" <<EOF
#!/bin/sh
exec node /usr/lib/$pkgname/bin/orbit.js "\$@"
EOF
  chmod +x "$pkgdir/usr/bin/orbit"
}
